source "https://rubygems.org"

# GitHub Pages builds your site with this exact gem, which bundles the
# supported Jekyll version and plugins (jekyll-feed, jekyll-seo-tag,
# jekyll-sitemap, minima theme, etc.) so your local build matches
# what GitHub renders in production.
gem "github-pages", group: :jekyll_plugins

gem "webrick", "~> 1.8" if Gem::Version.new(RUBY_VERSION) >= Gem::Version.new("3.0")
